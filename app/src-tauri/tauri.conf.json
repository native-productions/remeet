{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Remeet",
  "version": "0.1.0",
  "identifier": "com.nativeproductions.remeet",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "popover",
        "title": "Remeet",
        "width": 340,
        "height": 484,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "focus": true,
        "shadow": false
      },
      {
        "label": "main",
        "title": "Remeet",
        "width": 1000,
        "height": 660,
        "minWidth": 760,
        "minHeight": 520,
        "resizable": true,
        "visible": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; media-src 'self' asset: http://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/Remeet/recordings/**",
          "$HOME/Remeet-dev/recordings/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "macOS": {
      "minimumSystemVersion": "15.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}